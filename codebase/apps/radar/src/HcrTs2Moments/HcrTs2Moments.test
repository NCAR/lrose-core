//          NOISE_BIAS_DB_VC
//          NOISE_FLAG
//          SIGNAL_FLAG
//          NOISE_INTEREST
//          SIGNAL_INTEREST
//          NOISE_ACCUM_PHASE_CHANGE
//          NOISE_PHASE_CHANGE_ERROR
//          NOISE_DBM_SDEV
//          NOISE_NCP_MEAN
//          SNR
//          SNRHC
//          SNRVC
//          DBM
//          DBMHC
//          DBMVC
//          DBMHC_NS
//          DBMVC_NS
